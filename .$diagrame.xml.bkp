        </mxCell>
        <mxCell id="bsl_db" value="Base de Données" style="swimlane;startSize=30;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="860" y="60" width="200" height="900" as="geometry" />
        </mxCell>

        <!-- START -->
        <mxCell id="bstart" value="" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="90" y="110" width="40" height="40" as="geometry" />
        </mxCell>

        <!-- 1. Choisir locataire + unité -->
        <mxCell id="b1" value="Sélectionner locataire + unité libre + paramètres bail" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="30" y="180" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- 2. POST /api/bail/add -->
        <mxCell id="b2" value="POST /api/bail/add&#xa;(JWT Proprietaire)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="250" y="180" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- 3. @PreAuthorize check -->
        <mxCell id="b3" value="@PreAuthorize('hasRole(PROPRIETAIRE)')" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="250" y="270" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- Decision: rôle ok? -->
        <mxCell id="bd1" value="Autorisé?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="265" y="360" width="130" height="70" as="geometry" />
        </mxCell>

        <mxCell id="berr1" value="HTTP 403 Forbidden" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="250" y="460" width="160" height="40" as="geometry" />
        </mxCell>

        <!-- 4. findByUuid locataire -->
        <mxCell id="b4" value="findByUuid(locataireUuid)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="880" y="365" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- Decision: locataire trouvé? -->
        <mxCell id="bd2" value="Locataire trouvé?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="465" y="360" width="150" height="70" as="geometry" />
        </mxCell>

        <mxCell id="berr2" value="RuntimeException: Locataire introuvable → 500" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="460" y="460" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- 5. findByUuid unite -->
        <mxCell id="b5" value="findByUuid(uniteUuid)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="880" y="450" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- Decision: unité libre? -->
        <mxCell id="bd3" value="Unité trouvée?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="465" y="530" width="150" height="70" as="geometry" />
